# PostgreSQL Database URL (pooled connection for runtime queries)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Direct connection (non-pooled, for Prisma migrations and schema pushes)
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# For Vercel + Neon Postgres, get these from the Vercel dashboard:
# DATABASE_URL = moling_POSTGRES_PRISMA_URL (pooled)
# DIRECT_URL = moling_DATABASE_URL_UNPOOLED (non-pooled)
